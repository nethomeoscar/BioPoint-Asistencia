{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "Represents a staff member registered for facial attendance.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the employee" },
        "department": { "type": "string", "description": "Working department" },
        "faceDescriptor": { "type": "array", "description": "Array of 128 biometric descriptors generated by face-api.js" },
        "shiftStart": { "type": "string", "description": "Scheduled entry time (HH:mm)" },
        "shiftEnd": { "type": "string", "description": "Scheduled exit time (HH:mm)" },
        "companyId": { "type": "string", "description": "Unique identifier for the organization" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "department", "companyId"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "A single clock-in or clock-out event.",
      "type": "object",
      "properties": {
        "employeeId": { "type": "string", "description": "Reference to the Employee document ID" },
        "name": { "type": "string", "description": "Name captured or recognized" },
        "department": { "type": "string", "description": "Department of the attendee" },
        "date": { "type": "string", "description": "ISO date string YYYY-MM-DD" },
        "time": { "type": "string", "description": "Time string HH:mm:ss" },
        "type": { "type": "string", "enum": ["Entrada", "Salida"] },
        "status": { "type": "string", "enum": ["Reconocido", "No reconocido"] },
        "punctuality": { "type": "string" },
        "timestamp": { "type": "number", "description": "Unix timestamp in ms" },
        "companyId": { "type": "string", "description": "Unique identifier for the organization" }
      },
      "required": ["name", "date", "time", "type", "status", "timestamp", "companyId"]
    }
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of registered employees."
    },
    "/attendance/{recordId}": {
      "schema": "AttendanceRecord",
      "description": "Historical log of all attendance events."
    }
  }
}
