rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function isVerified(cid) {
      // Check if user belongs to this company
      // Using path-based check is efficient for queries within subcollections
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == cid;
    }

    function isAdmin(cid) {
       return isVerified(cid) && (
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' ||
         request.auth.token.email == "omicin@hotmail.com"
       );
    }

    match /test/connection {
      allow read: if true;
    }

    // --- Users collection (Global mapping) ---
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid && incoming().diff(existing()).affectedKeys().hasOnly(['companyId', 'role', 'pairedAt']);
    }

    // --- Companies and their sub-data ---
    match /companies/{cid} {
      allow read: if isSignedIn() && (resource.data.ownerUid == request.auth.uid || isVerified(cid));
      allow create: if isSignedIn() && incoming().ownerUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerUid == request.auth.uid;

      match /employees/{eid} {
        allow read: if isVerified(cid);
        allow write: if isAdmin(cid);
      }

      match /attendance/{rid} {
        allow read, create: if isVerified(cid);
        allow list: if isVerified(cid);
        allow delete: if isAdmin(cid);
      }
    }

    // --- Legacy / Global collections (to avoid breaking immediately) ---
    match /employees/{eid} {
      allow read, write: if isSignedIn() && (request.auth.token.email == "omicin@hotmail.com" || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId);
    }
    match /attendance/{rid} {
      allow read, write: if isSignedIn() && (request.auth.token.email == "omicin@hotmail.com" || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == resource.data.companyId);
    }
  }
}
