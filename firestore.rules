rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "omicin@hotmail.com"
      );
    }

    function getCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Employee Rules ---
    match /employees/{employeeId} {
      function isValidEmployee(data) {
        return data.keys().hasAll(['name', 'department', 'companyId']) 
            && data.name is string && data.name.size() > 0 && data.name.size() <= 100
            && data.department is string && data.department.size() <= 100
            && data.companyId is string
            && (!data.keys().contains('shiftStart') || (data.shiftStart is string && data.shiftStart.matches('^\\d{2}:\\d{2}$')))
            && (!data.keys().contains('shiftEnd') || (data.shiftEnd is string && data.shiftEnd.matches('^\\d{2}:\\d{2}$')))
            && (!data.keys().contains('faceDescriptor') || data.faceDescriptor is list);
      }

      // Both kiosks and admins can read employees of their own company
      allow read: if isSignedIn() && resource.data.companyId == getCompanyId();
      
      allow create: if isVerifiedAdmin() && isValidEmployee(incoming()) && incoming().companyId == getCompanyId();
      allow update: if isVerifiedAdmin() && isValidEmployee(incoming()) && incoming().companyId == getCompanyId() && resource.data.companyId == getCompanyId();
      allow delete: if isVerifiedAdmin() && resource.data.companyId == getCompanyId();
    }

    // --- Attendance Rules ---
    match /attendance/{recordId} {
      function isValidRecord(data) {
        return data.keys().hasAll(['name', 'type', 'status', 'timestamp', 'date', 'time', 'companyId'])
            && data.name is string && data.name.size() <= 100
            && data.type in ['Entrada', 'Salida']
            && data.status in ['Reconocido', 'No reconocido']
            && data.timestamp is number
            && data.companyId is string
            && data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$')
            && data.time is string && data.time.matches('^\\d{2}:\\d{2}:\\d{2}$');
      }

      allow list: if isSignedIn() && resource.data.companyId == getCompanyId();
      
      allow create: if isSignedIn() && isValidRecord(incoming()) && incoming().companyId == getCompanyId();
      allow get: if isSignedIn() && resource.data.companyId == getCompanyId();
      allow delete: if isVerifiedAdmin() && resource.data.companyId == getCompanyId();
    }

    // --- Users collection (mapping uid to company) ---
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      // Allow creation if user is logging in for the first time
      allow create: if isSignedIn() && request.auth.uid == uid;
    }

    // --- Admins collection ---
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
